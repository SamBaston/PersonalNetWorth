{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx tsx server.ts",
    "build": "npx shx mkdir -p dist && npx shx cp -r public dist/ && npx tsc server.ts --esModuleInterop --module esnext --target es2017 --moduleResolution bundler --outDir dist",
    "prestart": "npm run build",
    "postinstall": "npm run build",
    "start": "node dist/server.js",
    "lint": "npx eslint .",
    "test": "NODE_OPTIONS=--experimental-vm-modules npx jest",
    "clean": "npx shx rm -rf dist"
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "@hookform/resolvers": "^5.2.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "express": "^5.2.1",
    "jest": "^30.2.0",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "supertest": "^7.2.2",
    "tailwind-merge": "^3.3.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/cors": "^2.8.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.0.0",
    "shx": "^0.4.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
}
